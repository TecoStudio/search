---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';

export const prerender = false;

const all = await getCollection('docs');
const docs = all.map((e) => ({
  slug: e.id,
  title: e.data.title,
  order: e.data.order,
}));

const intro =
  all.find((e) => e.id === 'introduction') ??
  [...all].sort((a, b) => a.data.order - b.data.order)[0];

const { Content } = await render(intro);
---

<DocsLayout
  docs={docs}
  current={intro.id}
  title={intro.data.title}
  description={intro.data.description}
  endpoint={intro.data.endpoint}
>
  <Content />
</DocsLayout>
