---
import Layout from '../../layouts/Layout.astro';
import { Server, ImageDown, Palette } from 'lucide-astro';

const tools = [
  {
    href: '/server',
    icon: Server,
    title: '服务器状态查询',
    desc: 'Java / 基岩版实时 ping，MOTD、玩家、延迟，SRV 自动解析。',
    ready: true,
  },
  {
    href: '/docs/server-banner',
    icon: ImageDown,
    title: '状态 Banner 生成',
    desc: '实时渲染服务器状态横幅 PNG，可直接嵌入网页或 README。',
    ready: true,
  },
  {
    href: '/docs/server-icon',
    icon: Palette,
    title: '服务器图标',
    desc: '提取服务器 favicon，输出 64×64 PNG，缺省返回占位图。',
    ready: true,
  },
];
---

<Layout title="小工具">
  <div class="space-y-2">
    <h1 class="text-2xl font-bold">小工具</h1>
    <p class="text-sm text-mc-muted">MCSearch 提供的实用小工具集合。</p>
  </div>

  <section class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {
      tools.map((t) => (
        <a
          href={t.href}
          class="group rounded-xl border border-mc-border bg-mc-surface p-5 transition hover:border-mc-grass/60"
        >
          <div class="flex items-center justify-between">
            <span class="grid size-10 place-items-center rounded-lg bg-mc-surface-2 text-mc-grass">
              <t.icon class="size-5" />
            </span>
            {!t.ready && (
              <span class="rounded bg-mc-surface-2 px-2 py-0.5 text-[10px] text-mc-muted">
                即将上线
              </span>
            )}
          </div>
          <h2 class="mt-3 font-semibold group-hover:text-mc-grass">{t.title}</h2>
          <p class="mt-1 text-sm text-mc-muted">{t.desc}</p>
        </a>
      ))
    }
  </section>
</Layout>
