---
import Layout from '../layouts/Layout.astro';
import { Search } from 'lucide-astro';
---

<Layout>
  <section
    class="flex flex-col items-center justify-center py-20 text-center sm:py-28"
  >
    <h1 class="text-5xl font-extrabold tracking-tight sm:text-6xl">
      搜遍 <span class="text-mc-grass">MC</span> 世界
    </h1>
    <p class="mt-3 text-mc-muted">MCSearch — 简体中文 Minecraft 综合搜索</p>

    <form action="/search" method="get" role="search" class="mt-8 w-full max-w-xl">
      <div
        class="flex items-center gap-2 rounded-full border border-mc-border bg-mc-surface px-5 py-2.5 shadow-sm transition focus-within:border-mc-grass"
      >
        <Search class="size-5 shrink-0 text-mc-muted" aria-hidden="true" />
        <input
          type="search"
          name="q"
          placeholder="搜索 Mod、整合包、服务器…"
          autocomplete="off"
          spellcheck="false"
          autofocus
          class="min-w-0 flex-1 bg-transparent py-1 text-base outline-none placeholder:text-mc-muted"
        />
        <button
          type="submit"
          class="shrink-0 rounded-full bg-mc-grass px-4 py-1.5 text-sm font-semibold text-[#06210a] transition hover:bg-mc-grass-dark"
        >
          搜索
        </button>
      </div>
    </form>

    <nav
      class="mt-6 flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-sm text-mc-muted"
    >
      <a href="/tools" class="hover:text-mc-text">小工具</a>
      <a href="/docs" class="hover:text-mc-text">API 文档</a>
      <a href="/playground" class="hover:text-mc-text">Playground</a>
    </nav>
  </section>
</Layout>
