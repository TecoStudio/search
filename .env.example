# MCSearch environment variables — copy to `.env` and fill in as needed.
# Everything here is optional; unset values degrade gracefully.

# Redis connection string. Unset -> all caching becomes a no-op.
# REDIS_URL=redis://localhost:6379

# The Mod search site: sources (MC百科 / B站 / BBSPK forums) are scraped from
# Bing using headless Chromium (no API key). Chromium must exist on the host;
# CHROMIUM_PATH points at it and defaults to /usr/bin/chromium (baked into the
# Docker image). On macOS dev, set it to a local Chrome/Chromium binary, e.g.
# CHROMIUM_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# CHROMIUM_PATH=/usr/bin/chromium

# CurseForge API key. Required for the CurseForge native source; unset -> it is
# skipped in `all` mode and returns 503 when requested directly.
# Modrinth needs no key. Get one at https://console.curseforge.com/
# CURSEFORGE_API_KEY=

# Override the Banner font directory (defaults to src/assets/fonts/).
# FONTS_DIR=
